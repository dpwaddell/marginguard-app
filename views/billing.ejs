<%- include('layout', { body: `
<div class="page">
  <div class="page-header">
    <div>
      <h1>Billing</h1>
      <div class="page-subtitle">Manage your MarginGuard subscription</div>
    </div>
  </div>

  <div id="billing-status" style="margin-bottom:16px"></div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:760px;align-items:start">
    <div class="card" id="free-card" style="border:2px solid #e5e7eb;position:relative">
      <div style="font-size:20px;font-weight:700;margin-bottom:4px;color:#111827">Free</div>
      <div style="font-size:32px;font-weight:800;margin-bottom:4px;color:#111827">$0<span style="font-size:15px;font-weight:400;color:#6b7280">/month</span></div>
      <div style="font-size:12px;color:#6b7280;margin-bottom:16px">No credit card required</div>
      <ul style="list-style:none;font-size:13px;line-height:1">
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#6b7280"><span style="color:#059669;margin-right:8px">✓</span>Last 50 orders</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#6b7280"><span style="color:#059669;margin-right:8px">✓</span>Up to 3 cost rules</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#6b7280"><span style="color:#059669;margin-right:8px">✓</span>Product cost health</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#c9cccf"><span style="margin-right:8px">✗</span>Product tag rules</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#c9cccf"><span style="margin-right:8px">✗</span>Email alerts</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f3;color:#c9cccf"><span style="margin-right:8px">✗</span>Order auto-tagging</li>
        <li style="padding:6px 0;color:#c9cccf"><span style="margin-right:8px">✗</span>Full order history</li>
      </ul>
      <div style="margin-top:20px" id="free-action">
        <span style="display:inline-block;background:#f3f4f6;color:#6b7280;font-size:12px;font-weight:600;padding:6px 14px;border-radius:6px">Current plan</span>
      </div>
    </div>

    <div class="card" id="pro-card" style="border:2px solid #008060;position:relative;box-shadow:0 6px 20px rgba(0,128,96,0.15);padding-top:28px">
      <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#008060;color:#fff;font-size:11px;font-weight:700;padding:3px 14px;border-radius:20px;white-space:nowrap;text-transform:uppercase;letter-spacing:0.07em">Most Popular</div>
      <div style="font-size:20px;font-weight:700;margin-bottom:4px;color:#1a1c1e">Pro</div>
      <div style="font-size:32px;font-weight:800;margin-bottom:2px;color:#1a1c1e">$49<span style="font-size:15px;font-weight:400;color:#8c9196">/month</span></div>
      <div style="font-size:12px;color:#008060;font-weight:600;margin-bottom:4px">Start with a 14-day free trial</div>
      <div style="font-size:12px;color:#8c9196;margin-bottom:16px">No charge for 14 days. $49/month after trial.</div>
      <ul style="list-style:none;font-size:13px;line-height:1">
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>14-day free trial included</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>All Free features</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Full order history</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Unlimited cost rules</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Product tag cost rules</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Email alerts</li>
        <li style="padding:6px 0;border-bottom:1px solid #f1f2f4;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Auto-tag low-margin orders</li>
        <li style="padding:6px 0;color:#1a1c1e"><span style="color:#008060;font-weight:700;margin-right:8px">✓</span>Priority support</li>
      </ul>
      <div style="margin-top:20px" id="pro-action">
        <button class="btn btn-primary" id="upgrade-btn" style="width:100%;justify-content:center;font-size:14px;height:40px">Start Free Trial →</button>
        <div style="text-align:center;font-size:12px;color:#8c9196;margin-top:8px">No charge for 14 days</div>
      </div>
    </div>
  </div>
</div>

<script>
  async function loadBillingStatus() {
    const cancelledParam = new URLSearchParams(window.location.search).get('plan') === 'cancelled';
    const declinedParam = new URLSearchParams(window.location.search).get('billing') === 'declined';
    try {
      var shop = (window.__MARGINGUARD__ && window.__MARGINGUARD__.shop) || getCookie('mg_shop') || '';
      var headers = {};
      try { const token = await getSessionToken(); headers['Authorization'] = 'Bearer ' + token; } catch(e) {}
      const res = await fetch('/api/billing/status?shop=' + shop, { headers });
      const data = await res.json();
      if (cancelledParam) {
        const bar = document.getElementById('billing-status');
        bar.innerHTML = '<div class="alert-bar" style="display:flex;align-items:center;justify-content:space-between">Your subscription has been cancelled. You\\'re now on the Free plan.<button onclick="this.closest(\\'.alert-bar\\').remove()" style="background:none;border:none;cursor:pointer;font-size:16px;color:#6b7280;line-height:1;padding:0 0 0 12px">×</button></div>';
      }
      if (data.plan === 'Pro') {
        document.getElementById('free-action').innerHTML = '';
        document.getElementById('pro-action').innerHTML =
          '<span style="display:inline-block;background:#008060;color:#fff;font-size:12px;font-weight:600;padding:6px 14px;border-radius:6px">Current plan ✓</span>' +
          '<div style="text-align:center;margin-top:10px"><button id="cancel-btn" style="background:none;border:none;cursor:pointer;font-size:12px;color:#8c9196;text-decoration:underline;padding:0">Cancel subscription</button></div>';
        document.getElementById('free-card').style.borderColor = '#e5e7eb';
        document.getElementById('pro-card').style.borderColor = '#008060';
        document.getElementById('billing-status').innerHTML = '<div class="alert-bar success">✓ You are on the <strong>Pro plan</strong>. Thank you for supporting MarginGuard!</div>';
        attachCancelBtn();
      } else if (declinedParam) {
        document.getElementById('billing-status').innerHTML = '<div class="alert-bar danger">⚠ Your billing was declined. Please try again to access Pro features.</div>';
        document.getElementById('pro-action').innerHTML = '<button class="btn btn-primary" id="retry-billing-btn" style="width:100%;justify-content:center;font-size:14px;height:40px">Try again →</button><div style="text-align:center;font-size:12px;color:#8c9196;margin-top:8px">No charge for 14 days</div>';
        document.getElementById('retry-billing-btn').addEventListener('click', async function() {
          const status = document.getElementById('billing-status');
          status.innerHTML = '<div class="alert-bar">Redirecting to Shopify billing...</div>';
          try {
            var rHeaders = {};
            try { const token = await getSessionToken(); rHeaders['Authorization'] = 'Bearer ' + token; } catch(e) {}
            const res = await fetch('/billing/subscribe', { method: 'POST', headers: rHeaders });
            const retryData = await res.json().catch(() => ({}));
            if (retryData.confirmation_url) {
              window.top.location.href = retryData.confirmation_url;
            } else {
              const errDiv = document.createElement('div');
              errDiv.className = 'alert-bar danger';
              errDiv.textContent = 'Billing error: ' + (retryData.error || 'Unknown error');
              status.replaceChildren(errDiv);
            }
          } catch(e) {
            status.innerHTML = '<div class="alert-bar danger">Failed to start subscription. Please try again.</div>';
          }
        });
      }
    } catch(e) { console.error('[Billing] Status load failed:', e); }
  }

  function attachCancelBtn() {
    var btn = document.getElementById('cancel-btn');
    if (!btn) return;
    btn.addEventListener('click', async function() {
      if (!confirm('Are you sure you want to cancel your Pro subscription?')) return;
      var shop = (window.__MARGINGUARD__ && window.__MARGINGUARD__.shop) || getCookie('mg_shop') || '';
      var cHeaders = {};
      try { const token = await getSessionToken(); cHeaders['Authorization'] = 'Bearer ' + token; } catch(e) {}
      var status = document.getElementById('billing-status');
      try {
        const res = await fetch('/billing/cancel?shop=' + shop, { method: 'POST', headers: cHeaders });
        if (res.ok) {
          status.innerHTML = '<div class="alert-bar success">Subscription cancelled. You are now on the Free plan.</div>';
          loadBillingStatus();
        } else {
          const errData = await res.json().catch(() => ({}));
          status.innerHTML = '<div class="alert-bar danger">Error: ' + (errData.error || 'Could not cancel. Please try again.') + '</div>';
        }
      } catch(e) {
        status.innerHTML = '<div class="alert-bar danger">Failed to cancel. Please try again.</div>';
      }
    });
  }

  function attachUpgradeBtn() {
    var btn = document.getElementById('upgrade-btn');
    if (!btn) return;
    btn.addEventListener('click', async function() {
      console.log('Billing button clicked');
      var status = document.getElementById('billing-status');
      status.innerHTML = '<div class="alert-bar">Redirecting to Shopify billing...</div>';
      try {
        var shop = (window.__MARGINGUARD__ && window.__MARGINGUARD__.shop) || getCookie('mg_shop') || '';
        var bHeaders = {};
        try { const token = await getSessionToken(); bHeaders['Authorization'] = 'Bearer ' + token; } catch(e) {}
        const res = await fetch('/billing/subscribe?shop=' + shop, {
          method: 'POST',
          headers: bHeaders
        });
        const subData = await res.json().catch(() => ({}));
        if (subData.confirmation_url) {
          window.top.location.href = subData.confirmation_url;
        } else {
          const errDiv = document.createElement('div');
          errDiv.className = 'alert-bar danger';
          errDiv.textContent = 'Billing error: ' + (subData.error || 'Unknown error');
          status.replaceChildren(errDiv);
        }
      } catch(e) {
        status.innerHTML = '<div class="alert-bar danger">Failed to start subscription. Please try again.</div>';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      attachUpgradeBtn();
      attachCancelBtn();
      loadBillingStatus();
    });
  } else {
    attachUpgradeBtn();
    attachCancelBtn();
    loadBillingStatus();
  }
</script>
` }) %>
