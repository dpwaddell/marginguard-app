<%- include('layout', { body: `
<div class="page">
  <div class="page-header">
    <div>
      <h1>Dashboard</h1>
      <div class="page-subtitle">Track profitability and identify margin risks</div>
    </div>
    <div class="flex gap-2 items-center">
      <select class="form-input" id="range-select" style="width:auto;min-width:130px">
        <option value="1d">Today</option>
        <option value="7d" selected>Last 7 days</option>
        <option value="30d">Last 30 days</option>
        <option value="90d">Last 90 days</option>
      </select>
    </div>
  </div>

  <div id="onboarding-container"></div>
  <div id="alert-container"></div>

  <div class="section-label" style="margin-top:4px">Performance overview</div>
  <div class="stat-grid" id="summary-stats">
    <div class="stat-card accent-blue">
      <div class="stat-label">Total Revenue</div>
      <div class="stat-value" id="stat-revenue">—</div>
      <div class="stat-trend" id="trend-revenue"></div>
    </div>
    <div class="stat-card accent-amber">
      <div class="stat-label">Discounts Given</div>
      <div class="stat-value warning" id="stat-discounts">—</div>
      <div class="stat-trend" id="trend-discounts"></div>
    </div>
    <div class="stat-card accent-grey">
      <div class="stat-label">Total Costs</div>
      <div class="stat-value" id="stat-costs">—</div>
      <div class="stat-trend" id="trend-costs"></div>
    </div>
    <div class="stat-card accent-green">
      <div class="stat-label">Net Profit</div>
      <div class="stat-value" id="stat-profit">—</div>
      <div class="stat-trend" id="trend-profit"></div>
    </div>
    <div class="stat-card accent-green">
      <div class="stat-label">Avg Margin</div>
      <div class="stat-value" id="stat-margin">—</div>
      <div class="stat-trend" id="trend-margin"></div>
    </div>
    <div class="stat-card accent-amber">
      <div class="stat-label">Low-Margin Orders</div>
      <div class="stat-value warning" id="stat-low-margin">—</div>
    </div>
    <div class="stat-card accent-red">
      <div class="stat-label">Missing Product Costs</div>
      <div class="stat-value" id="stat-missing-cogs">—</div>
    </div>
  </div>

  <div id="last-updated-ts" style="font-size:11px;color:#9ca3af;margin-bottom:16px"></div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">Orders at risk — lowest margins</span>
      <span id="risk-count-badge"></span>
    </div>
    <table id="low-margin-table">
      <thead>
        <tr>
          <th>Order</th>
          <th>Date</th>
          <th>Revenue</th>
          <th class="text-right">Net Profit</th>
          <th class="text-right">Margin</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="low-margin-rows">
        <tr><td colspan="6" class="loading">Loading...</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card" id="top-products-card" style="display:none">
    <div class="card-header">
      <span class="card-title">Top Products by Revenue</span>
    </div>
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Variant</th>
          <th class="text-right">Orders</th>
          <th class="text-right">Revenue</th>
          <th class="text-right">Profit</th>
          <th class="text-right">Avg Margin</th>
          <th>Cost data</th>
        </tr>
      </thead>
      <tbody id="top-products-tbody"></tbody>
    </table>
  </div>

  <div style="margin-top:16px;display:flex;gap:12px">
    <a href="/app/orders" class="btn btn-secondary btn-sm">View all orders →</a>
    <a href="/app/products" class="btn btn-secondary btn-sm">Fix missing product costs →</a>
  </div>
</div>

<script>
  const appBase = '${appUrl}';
  let currentRange = '7d';

  async function authHeaders() {
    var headers = {};
    try { headers['Authorization'] = 'Bearer ' + await getSessionToken(); } catch(e) {}
    return headers;
  }

  function shopParam() {
    return (window.__MARGINGUARD__ && window.__MARGINGUARD__.shop) || getCookie('mg_shop') || '';
  }

  async function fetchDashboard(range) {
    try {
      const shop = shopParam();
      const headers = await authHeaders();
      const [res, prodRes] = await Promise.all([
        fetch(appBase + '/api/dashboard?range=' + range + '&shop=' + shop, { headers }),
        fetch(appBase + '/api/dashboard/products?range=' + range + '&shop=' + shop, { headers }),
      ]);
      if (!res.ok) {
        document.getElementById('low-margin-rows').innerHTML = '<tr><td colspan="6" style="color:#dc2626;padding:20px">Failed to load dashboard data.</td></tr>';
        return;
      }
      const data = await res.json();
      const prodData = prodRes.ok ? await prodRes.json() : null;
      renderDashboard(data);
      if (prodData) renderTopProducts(prodData.products || []);
    } catch(e) {
      console.error('[Dashboard] fetch error:', e.message);
      document.getElementById('low-margin-rows').innerHTML = '<tr><td colspan="6" style="color:#dc2626;padding:20px">Failed to load dashboard data.</td></tr>';
    }
  }

  function fmt(n) { return '£' + (parseFloat(n) || 0).toFixed(2).replace(/\\B(?=(\\d{3})+(?!\\d))/g, ','); }
  function fmtPct(n) { return n == null ? '—' : parseFloat(n).toFixed(1) + '%'; }

  function renderTrend(curr, prev, elementId, lowerIsBetter) {
    var el = document.getElementById(elementId);
    if (!el) return;
    var c = parseFloat(curr) || 0;
    var p = parseFloat(prev) || 0;
    if (p === 0) { el.innerHTML = ''; return; }
    var pct = ((c - p) / Math.abs(p)) * 100;
    var up = pct > 0.05;
    var down = pct < -0.05;
    if (!up && !down) { el.innerHTML = '<span class="trend-neutral">— flat vs prev period</span>'; return; }
    var good = lowerIsBetter ? down : up;
    var arrow = up ? '▲' : '▼';
    var cls = up ? (good ? 'trend-up-good' : 'trend-up-bad') : (good ? 'trend-down-good' : 'trend-down-bad');
    el.innerHTML = '<span class="' + cls + '">' + arrow + ' ' + Math.abs(pct).toFixed(1) + '%</span>';
  }

  function renderDashboard(data) {
    var s = data.summary || {};
    var p = data.prev_summary || {};

    document.getElementById('stat-revenue').textContent = fmt(s.total_revenue);
    document.getElementById('stat-discounts').textContent = fmt(s.total_discounts);
    document.getElementById('stat-costs').textContent = fmt(s.total_costs);
    var profitEl = document.getElementById('stat-profit');
    var profit = parseFloat(s.total_profit) || 0;
    profitEl.textContent = fmt(profit);
    profitEl.className = 'stat-value ' + (profit >= 0 ? 'positive' : 'negative');
    document.getElementById('stat-margin').textContent = fmtPct(s.avg_margin);
    document.getElementById('stat-low-margin').textContent = data.low_margin_count || 0;
    var missingEl = document.getElementById('stat-missing-cogs');
    missingEl.textContent = data.missing_cogs_count || 0;
    missingEl.className = 'stat-value' + (data.missing_cogs_count > 0 ? ' warning' : ' positive');

    renderTrend(s.total_revenue, p.total_revenue, 'trend-revenue', false);
    renderTrend(s.total_discounts, p.total_discounts, 'trend-discounts', true);
    renderTrend(s.total_costs, p.total_costs, 'trend-costs', true);
    renderTrend(s.total_profit, p.total_profit, 'trend-profit', false);
    renderTrend(s.avg_margin, p.avg_margin, 'trend-margin', false);

    var tsEl = document.getElementById('last-updated-ts');
    if (tsEl) tsEl.textContent = 'Last updated: ' + new Date().toLocaleTimeString('en-GB');

    var riskRows = data.top_low_margin_orders || [];
    var riskBadge = document.getElementById('risk-count-badge');
    if (riskBadge) {
      riskBadge.innerHTML = riskRows.length > 0
        ? '<span class="badge badge-danger">' + riskRows.length + ' at risk</span>'
        : '';
    }

    var alertCon = document.getElementById('alert-container');
    var alerts = [];
    if (data.low_margin_count > 0) {
      alerts.push('<div class="alert-bar danger"><span class="alert-icon">⚠</span><div><strong>' + data.low_margin_count + ' low-margin order' + (data.low_margin_count > 1 ? 's' : '') + '</strong> this period — review to identify profit leakage. <a href="/app/orders?sort=margin_asc">Review now →</a></div></div>');
    }
    if (data.missing_cogs_count > 0) {
      var leakageNote = '';
      if (s.avg_margin) {
        var avgMargin = parseFloat(s.avg_margin) / 100;
        var revenuePerOrder = parseFloat(s.total_revenue) / Math.max(parseInt(s.order_count), 1);
        var estimatedLeakage = data.missing_cogs_count * revenuePerOrder * avgMargin;
        if (estimatedLeakage > 0) {
          leakageNote = ' Estimated profit at risk: <strong style="color:#2563eb">' + fmt(estimatedLeakage) + '</strong>.';
        }
      }
      alerts.push('<div class="alert-bar"><span class="alert-icon">⚠</span><div><strong>' + data.missing_cogs_count + ' order' + (data.missing_cogs_count > 1 ? 's' : '') + '</strong> have missing product costs — margin estimates may be understated.' + leakageNote + ' <a href="/app/products">Fix now →</a></div></div>');
    }
    alertCon.innerHTML = alerts.join('');

    var tbody = document.getElementById('low-margin-rows');
    if (!riskRows.length) {
      tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><h3>No orders yet</h3><p>Orders will appear here after the first sync.</p></div></td></tr>';
      return;
    }
    tbody.innerHTML = riskRows.map(function(o) {
      var margin = parseFloat(o.margin_percent);
      var marginClass = margin < 0 ? 'text-red' : margin < 15 ? 'text-amber' : 'text-green';
      var profitClass = parseFloat(o.net_profit) < 0 ? 'text-red' : 'text-green';
      var confidence = o.confidence_status || 'complete';
      var badgeClass = o.low_margin ? 'badge-danger' : 'badge-success';
      return '<tr>' +
        '<td><a href="/app/orders/' + o.order_id + '">' + (o.order_name || o.order_id) + '</a></td>' +
        '<td class="text-muted">' + (o.processed_at ? new Date(o.processed_at).toLocaleDateString('en-GB') : '—') + '</td>' +
        '<td>' + fmt(o.net_revenue) + '</td>' +
        '<td class="text-right ' + profitClass + '">' + fmt(o.net_profit) + '</td>' +
        '<td class="text-right ' + marginClass + '"><strong>' + fmtPct(o.margin_percent) + '</strong></td>' +
        '<td><span class="badge ' + badgeClass + '">' + (o.low_margin ? 'Low margin' : 'OK') + '</span>' +
        (confidence !== 'complete' ? ' <span class="badge badge-warning">' + confidenceLabel(confidence) + '</span>' : '') + '</td>' +
        '</tr>';
    }).join('');
  }

  function renderTopProducts(products) {
    if (!products.length) return;
    document.getElementById('top-products-card').style.display = '';
    document.getElementById('top-products-tbody').innerHTML = products.map(function(p) {
      var margin = parseFloat(p.avg_margin);
      var marginClass = isNaN(margin) ? '' : margin < 0 ? 'text-red' : margin < 15 ? 'text-amber' : 'text-green';
      return '<tr>' +
        '<td><strong>' + (p.product_title || '—') + '</strong></td>' +
        '<td class="text-muted">' + (p.variant_title || '—') + '</td>' +
        '<td class="text-right">' + (p.order_count || 0) + '</td>' +
        '<td class="text-right">' + fmt(p.total_revenue) + '</td>' +
        '<td class="text-right">' + fmt(p.total_profit) + '</td>' +
        '<td class="text-right ' + marginClass + '"><strong>' + fmtPct(p.avg_margin) + '</strong></td>' +
        '<td>' + (p.has_missing_cogs ? '<span class="badge badge-warning">Missing costs</span>' : '<span class="badge badge-success">Complete</span>') + '</td>' +
        '</tr>';
    }).join('');
  }

  function confidenceLabel(s) {
    var map = { estimated: 'Estimated', missing_cogs: 'Missing costs', missing_cost_settings: 'No cost rules' };
    return map[s] || s;
  }

  async function fetchOnboarding() {
    try {
      var shop = shopParam();
      var headers = await authHeaders();
      var res = await fetch(appBase + '/api/onboarding/status?shop=' + shop, { headers });
      if (!res.ok) { renderOnboarding({ has_products: false, has_cost_rules: false, has_orders: false, has_settings: false, completed: false }); return; }
      var data = await res.json();
      renderOnboarding(data);
    } catch(e) {
      renderOnboarding({ has_products: false, has_cost_rules: false, has_orders: false, has_settings: false, completed: false });
    }
  }

  function renderOnboarding(data) {
    console.log('[Onboarding] data:', JSON.stringify(data));
    var con = document.getElementById('onboarding-container');
    if (data.dismissed) { con.style.display = 'none'; return; }
    con.style.display = '';

    var steps = [
      { key: null,              always: true,       title: 'Install the app',              desc: 'MarginGuard is connected to your store',          action: null,          btnLabel: null },
      { key: 'has_products',    always: false,       title: 'Sync your products',           desc: 'Import your product catalogue from Shopify',      action: 'syncProducts', btnLabel: 'Sync Products' },
      { key: 'has_cost_rules',  always: false,       title: 'Add cost rules',               desc: 'Set up payment processing, shipping & fulfilment', action: 'goToCosts',    btnLabel: 'Add Cost Rules' },
      { key: 'has_orders',      always: false,       title: 'Sync your orders',             desc: 'Import recent orders to calculate margin data',   action: 'syncOrders',   btnLabel: 'Sync Orders' },
      { key: 'has_settings',    always: false,       title: 'Configure target margin',      desc: 'Set your margin goals and alert preferences',     action: 'goToSettings', btnLabel: 'Open Settings' },
    ];

    var doneCount = steps.filter(function(s) { return s.always || data[s.key]; }).length;
    var total = steps.length;
    var pct = Math.round((doneCount / total) * 100);

    var stepsHtml = steps.map(function(s, i) {
      var done = s.always || data[s.key];
      return '<div class="onboarding-step">' +
        '<div class="step-num ' + (done ? 'done' : 'pending') + '">' + (done ? '✓' : (i + 1)) + '</div>' +
        '<div class="step-body">' +
          '<div class="step-title ' + (done ? 'done' : '') + '">' + s.title + '</div>' +
          '<div class="step-desc">' + s.desc + '</div>' +
        '</div>' +
        '<div class="step-action">' +
          (!done && s.action
            ? '<button class="btn btn-secondary btn-sm" onclick="onboardAction(\\'' + s.action + '\\')">' + s.btnLabel + '</button>'
            : (done ? '<span style="font-size:12px;font-weight:600;color:#059669">Done ✓</span>' : '')) +
        '</div>' +
      '</div>';
    }).join('');

    con.innerHTML =
      '<div class="card" style="margin-bottom:20px;border-left:4px solid #059669">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">' +
          '<div>' +
            '<div style="font-size:16px;font-weight:800;color:#111827;letter-spacing:-0.02em">Get started with MarginGuard</div>' +
            '<div style="font-size:13px;color:#6b7280;margin-top:3px">Complete these steps to start tracking your margins</div>' +
          '</div>' +
          '<button onclick="dismissOnboarding()" style="background:none;border:none;color:#9ca3af;cursor:pointer;font-size:13px;padding:4px 8px;border-radius:6px;font-weight:500;transition:opacity 0.15s" onmouseenter="this.style.opacity=\\'0.6\\'" onmouseleave="this.style.opacity=\\'1\\'">Dismiss</button>' +
        '</div>' +
        '<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">' +
          '<div style="flex:1;background:#f3f4f6;border-radius:8px;height:6px;overflow:hidden">' +
            '<div style="background:linear-gradient(90deg,#059669,#10b981);height:100%;width:' + pct + '%;border-radius:8px;transition:width 0.5s ease"></div>' +
          '</div>' +
          '<div style="font-size:12px;font-weight:600;color:#6b7280;white-space:nowrap">' + doneCount + ' of ' + total + '</div>' +
        '</div>' +
        stepsHtml +
      '</div>';
  }

  async function dismissOnboarding() {
    document.getElementById('onboarding-container').style.display = 'none';
    try {
      var shop = shopParam();
      var headers = await authHeaders();
      headers['Content-Type'] = 'application/json';
      await fetch(appBase + '/api/onboarding/dismiss?shop=' + shop, { method: 'POST', headers });
    } catch(e) {}
  }

  async function onboardAction(action) {
    var shop = shopParam();
    var headers = await authHeaders();
    if (action === 'syncProducts') {
      await fetch(appBase + '/api/sync/products?shop=' + shop, { method: 'POST', headers });
      setTimeout(fetchOnboarding, 2000);
    } else if (action === 'syncOrders') {
      await fetch(appBase + '/api/sync/orders?shop=' + shop, { method: 'POST', headers });
      setTimeout(fetchOnboarding, 3000);
    } else if (action === 'goToCosts') {
      navigateTo('/app/costs');
    } else if (action === 'goToOrders') {
      navigateTo('/app/orders');
    } else if (action === 'goToSettings') {
      navigateTo('/app/settings');
    }
  }

  document.getElementById('range-select').addEventListener('change', function() {
    currentRange = this.value;
    fetchDashboard(currentRange);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { fetchDashboard(currentRange); fetchOnboarding(); });
  } else {
    fetchDashboard(currentRange);
    fetchOnboarding();
  }
</script>
` }) %>
